# Copy to ".env.runtime" for manual docker compose verification.
# Use it with:
#   docker compose --env-file .env.runtime config
#   docker compose --env-file .env.runtime up -d

# Required for image tags in docker-compose.yml.
# Replace with your actual GHCR owner/repo if you are pulling pushed images.
GITHUB_OWNER=shihaim
GITHUB_REPO=quant-trading
IMAGE_TAG=latest

# Postgres container.
POSTGRES_DB=trading
POSTGRES_USER=trader
POSTGRES_PASSWORD=change-this-strong-password

# App runtime.
TRADE_MODE=PAPER
UPBIT_ACCESS_KEY=
UPBIT_SECRET_KEY=
UPBIT_BASE_URL=https://api.upbit.com
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
OPS_API_ALLOW_ORIGIN=*
OPS_API_AUTH_SECRET=dev-ops-auth-secret-change-me
OPS_API_AUTH_TOKEN_TTL_SECONDS=43200
OPS_API_CREDENTIALS_ENCRYPTION_KEY=dev-ops-credentials-encryption-key-change-me

# Leave empty for the current apps/web/lib/api.ts behavior.
NEXT_PUBLIC_API_BASE_URL=

# Optional tuning / logging.
POLL_INTERVAL_SECONDS=1
CONFIG_RELOAD_SECONDS=15
MIN_STRATEGY_CANDLES=120
ORDER_RETRY_MAX=3
ORDER_RETRY_BACKOFF_SECONDS=0.8
DEFAULT_FEE_RATE=0.0005
PAPER_INITIAL_CASH_KRW=1000000
ENFORCE_MARKET_ALLOWLIST=false
ALLOWLIST_MARKETS=["KRW-BTC"]
REHEARSAL_ORDER_NOTIONAL_KRW=6000
LOG_LEVEL=INFO
LOG_DIR=logs
LOG_ROTATE_MAX_BYTES=10485760
LOG_ROTATE_BACKUP_COUNT=10

# Optional override. If omitted, docker-compose.yml derives this from POSTGRES_*.
# DATABASE_URL=postgresql+psycopg://trader:change-this-strong-password@postgres:5432/trading
