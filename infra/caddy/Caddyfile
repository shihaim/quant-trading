qt-dashboard.local {
  tls internal
  # Optional dashboard protection.
  # basicauth /* {
  #   admin <bcrypt-hash>
  # }

  # Client-side logs should stay on the Next.js app.
  handle /api/logs* {
    reverse_proxy web:3000
  }

  # Preserve the /api prefix for ops-api routes.
  handle /api/* {
    reverse_proxy ops-api:8080
  }

  handle {
    reverse_proxy web:3000
  }
}
